#lang racket

;; Ex.7
;; Newton method for cubic root of a
(define (newton3 a)
  (letrec ([good? (lambda (x)
                    (< (abs (- (* x x x) a)) 1e-10))]
           [next  (lambda (x)
                    (/ (+ (* 2.0 x) (/ a (* x x))) 3.0))]
           [it    (lambda (x)
                    (if (good? x) x (it (next x))))])
    (cond
      [(= a 0) 0.0]
      [else (it 1.0)])))

(displayln "Ex.7")
(displayln (newton3 8))
(displayln (newton3 27))
(displayln (newton3 64))
