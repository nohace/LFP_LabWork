#lang racket

;; Ex.8
;; Corrected from the PDF typo:
;; (let ([r (remainder a 2)]) ...)
(define (foo a b)
  (let ([r (remainder a 2)])
    (cond
      [(= a 1) b]
      [(= r 0) (foo (/ a 2) (* b 2))]
      [else (+ (foo (/ (- a 1) 2) (* b 2)) b)])))

;; Tail-recursive version
(define (bar a b)
  (define (loop a b acc)
    (let ([r (remainder a 2)])
      (cond
        [(= a 1) (+ acc b)]
        [(= r 0) (loop (/ a 2) (* b 2) acc)]
        [else (loop (/ (- a 1) 2) (* b 2) (+ acc b))])))
  (loop a b 0))

(displayln "Ex.8")
(displayln "(a) foo is NOT tail recursive, because in the odd case work remains after the recursive call.")
(displayln "(b) foo(a,b) computes a * b.")
(displayln "(c) bar is a tail-recursive version of foo.")
(displayln (foo 13 7))
(displayln (bar 13 7))
(displayln (foo 25 4))
(displayln (bar 25 4))
