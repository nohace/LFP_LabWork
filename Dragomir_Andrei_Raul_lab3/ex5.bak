#lang racket

;; Ex.5
;; Polynomial evaluation
;; lst = (a0 a1 ... an) represents a0 + a1*x + ... + an*x^n
(define (peval lst v)
  (define (loop coeffs acc)
    (if (null? coeffs)
        acc
        (loop (cdr coeffs) (+ (* acc v) (car coeffs)))))
  (loop (reverse lst) 0))

(displayln "Ex.5")
(displayln (peval '(1 2 3) 2))   ; 17
(displayln (peval '(5 -1 0 2) 3)) ; 56
